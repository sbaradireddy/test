except glue_client.exceptions.AlreadyExistsException:
    print("DB exists:  " + glue_db)

base_s3 = ("s3://" + OUTPUT_BUCKET + "/"
           + OUTPUT_PREFIX + "quicksight_tables")


def register_glue_table(tbl_name, s3_path, col_defs, pk=None):
    """Register a Parquet table in Glue Catalog."""
    gc   = boto3.client("glue")
    cols = []
    for col_name, col_type in col_defs:
        if col_name == pk:
            continue
        cols.append({"Name": col_name, "Type": col_type})

    part_keys = []
    if pk is not None:
        part_keys = [{"Name": pk, "Type": "string"}]

    tbl = {
        "Name": tbl_name,
        "StorageDescriptor": {
            "Columns"  : cols,
            "Location" : s3_path,
            "InputFormat": (
                "org.apache.hadoop.hive.ql.io"
                ".parquet.MapredParquetInputFormat"),
            "OutputFormat": (
                "org.apache.hadoop.hive.ql.io"
                ".parquet.MapredParquetOutputFormat"),
            "SerdeInfo": {
                "SerializationLibrary": (
                    "org.apache.hadoop.hive.ql.io"
                    ".parquet.serde.ParquetHiveSerDe"),
                "Parameters": {"serialization.format": "1"},
            },
            "Compressed"            : False,
            "StoredAsSubDirectories": True,
        },
        "PartitionKeys": part_keys,
        "TableType"    : "EXTERNAL_TABLE",
        "Parameters"   : {
            "classification": "parquet",
            "EXTERNAL"      : "TRUE",
        },
    }

    try:
        gc.create_table(DatabaseName=glue_db, TableInput=tbl)
        print("  Created  " + glue_db + "." + tbl_name)
    except gc.exceptions.AlreadyExistsException:
        gc.update_table(DatabaseName=glue_db, TableInput=tbl)
        print("  Updated  " + glue_db + "." + tbl_name)

    try:
        boto3.client("athena").start_query_execution(
            QueryString         = (
                "MSCK REPAIR TABLE "
                + glue_db + "." + tbl_name),
            ResultConfiguration = {
                "OutputLocation": (
                    "s3://" + OUTPUT_BUCKET
                    + "/athena-query-results/"),
            })
        print("  Partitions repaired: " + tbl_name)
    except Exception as e:
        print("  Partition repair skipped: " + str(e))


