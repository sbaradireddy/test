# ─────────────────────────────────────────────────────────────────────────────
# CELL 2 — List files
# ─────────────────────────────────────────────────────────────────────────────
import io, re, boto3
from collections import defaultdict

files_on_date = []
for page in boto3.client("s3").get_paginator("list_objects_v2").paginate(
        Bucket=SOURCE_BUCKET, Prefix=SOURCE_PREFIX):
    for obj in page.get("Contents", []):
        key = obj["Key"]
        if not key.lower().endswith(".parquet"):
            continue
        parts = key[len(SOURCE_PREFIX):].strip("/").split("/")
        if len(parts) < 3:
            continue
        date_folder = parts[0]
        if date_folder < DATE_FROM or date_folder > DATE_TO:
            continue
        filename    = parts[-1]
        stem        = filename.rsplit(".parquet", 1)[0]
        m           = re.match(r"^(SchemaType\d+)", stem, re.IGNORECASE)
        schema_type = m.group(1) if m else stem
        e = dict()
        e["s3_key"]      = key
        e["schema_type"] = schema_type
        e["filename"]    = filename
        e["size_bytes"]  = int(obj["Size"])
        files_on_date.append(e)

by_schema    = defaultdict(list)
for f in files_on_date:
    by_schema[f["schema_type"]].append(f)
schema_types = sorted(by_schema.keys())

print("CELL 2 DONE  files=" + str(len(files_on_date))
      + "  schemas=" + str(len(schema_types)))
for st in schema_types:
    kb = 0
    for f in by_schema[st]:
        kb = kb + f["size_bytes"]
    kb = kb / 1024
    print("  " + st + "  files=" + str(len(by_schema[st]))
          + "  kb=" + str(round(kb, 1)))


# ─────────────────────────────────────────────────────────────────────────────
# CELL 3 — Peek column counts
# ─────────────────────────────────────────────────────────────────────────────
import io, boto3
import pyarrow.parquet as pq

schema_col_counts = dict()
for st in schema_types:
    entry = by_schema[st][0]
    try:
        body  = boto3.resource("s3").Object(
            SOURCE_BUCKET, entry["s3_key"]).get()["Body"].read()
        buf   = io.BytesIO(body)
        tbl   = pq.read_table(buf)
        ncols = int(len(tbl.schema))
        nrows = int(tbl.num_rows)
        schema_col_counts[st] = ncols
        del tbl, buf, body
        print(st + "  rows=" + str(nrows) + "  cols=" + str(ncols))
    except Exception as e:
        schema_col_counts[st] = 0
        print(st + "  ERROR=" + str(e))

wide_list = []
for st in schema_types:
    if schema_col_counts[st] > WIDE_COLS:
        wide_list.append(st)
print("CELL 3 DONE  wide=" + str(wide_list))


# ─────────────────────────────────────────────────────────────────────────────
# CELL 4 — Helpers (pure Python, no Spark)
# ─────────────────────────────────────────────────────────────────────────────
import io, re, boto3
import pyarrow.parquet as pq

_ARR = re.compile(r"^(.+?)_\d+_(.+)$")

def logical_name(col):
    col = str(col)
    m   = _ARR.match(col)
    if m:
        return m.group(1) + "_" + m.group(2)
    return col

def read_parquet_as_pandas(bucket, key):
    import io as _io
    import boto3 as _b3
    import pyarrow.parquet as _pq
    body = _b3.resource("s3").Object(bucket, key).get()["Body"].read()
    buf  = _io.BytesIO(body)
    df   = _pq.read_table(buf).to_pandas()
    del buf, body
    return df

def safe_str(v):
    """Convert any value to plain Python str."""
    if v is None:
        return ""
    s = str(v)
    if s in ("None", "nan", "NaN", "NaT", "<NA>", "null"):
        return ""
    return s

def safe_int(v):
    """Convert any value to plain Python int."""
    try:
        return int(v)
    except Exception:
        return 0

def safe_float(v):
    """Convert any value to plain Python float."""
    try:
        return float(v)
    except Exception:
        return 0.0

print("CELL 4 DONE")


# ─────────────────────────────────────────────────────────────────────────────
# CELL 5 — Analyse one schema type (pure pandas, NO Spark at all)
# Returns three pandas DataFrames: profile_pdf, values_pdf, csv_pdf
# ─────────────────────────────────────────────────────────────────────────────

def analyse_schema(entries, schema_type, is_wide):
    import io as _io
    import boto3 as _b3
    import numpy as _np
    import pandas as _pd
    import pyarrow.parquet as _pq
    from collections import defaultdict as _dd

    # ── Step 1: read all files into one combined pandas DataFrame ─────────────
    frames = []
    for i in range(len(entries)):
        entry = entries[i]
        try:
            body = _b3.resource("s3").Object(
                SOURCE_BUCKET, entry["s3_key"]).get()["Body"].read()
            buf  = _io.BytesIO(body)
            df   = _pq.read_table(buf).to_pandas()
            del buf, body
            print("  [" + str(i+1) + "/" + str(len(entries)) + "] "
                  + entry["filename"]
                  + "  rows=" + str(len(df))
                  + "  cols=" + str(len(df.columns)))
            frames.append(df)
        except Exception as e:
            print("  SKIP " + entry["filename"] + ": " + str(e))

    if len(frames) == 0:
        empty_p = _pd.DataFrame(columns=[
            "schema_type","column_name","original_name","data_type",
            "total_rows","null_count","null_pct","distinct_count",
            "min_value","max_value","top_value"])
        empty_v = _pd.DataFrame(columns=[
            "schema_type","column_name","original_name","data_type",
            "value","value_count","value_pct","value_rank","total_rows"])
        empty_c = _pd.DataFrame(columns=[
            "schema_type","column_name","original_name","data_type",
            "value","value_count","value_pct","total_rows",
            "null_count","distinct_count","min_value","max_value"])
        return empty_p, empty_v, empty_c, 0

    combined   = _pd.concat(frames, ignore_index=True, sort=False)
    total_rows = int(len(combined))
    del frames
    print("  Combined: rows=" + str(total_rows)
          + "  cols=" + str(len(combined.columns)))

    # ── Step 2: build column list ─────────────────────────────────────────────
    raw_cols = list(combined.columns)
    if is_wide:
        # Map to logical names (strip array index)
        col_map = dict()
        for c in raw_cols:
            lc = logical_name(c)
            if lc not in col_map:
                col_map[lc] = []
            col_map[lc].append(c)
        work_cols = sorted(col_map.keys())
    else:
        col_map   = dict()
        for c in raw_cols:
            col_map[str(c)] = [str(c)]
        work_cols = [str(c) for c in raw_cols]

    # ── Step 3: per logical column, compute stats ─────────────────────────────
    profile_rows = []
    values_rows  = []
    csv_rows     = []

    null_replace = ["None", "nan", "NaN", "NaT", "<NA>", "null", ""]

    for lc in work_cols:
        # Merge all physical columns for this logical name into one series
        phys_cols  = col_map[lc]
        parts_list = []
        for pc in phys_cols:
            s = combined[pc].astype(str)
            parts_list.append(s)

        if len(parts_list) == 1:
            series = parts_list[0]
        else:
            series = _pd.concat(parts_list, ignore_index=True)

        # Replace null-like strings
        for ns in null_replace:
            series = series.replace(ns, _pd.NA)

        # Stats — all pure Python, no Spark
        null_count     = safe_int(series.isna().sum())
        non_null       = series.dropna()
        distinct_count = safe_int(non_null.nunique())

        # min / max using sorted list (avoids PySpark min/max shadow)
        if len(non_null) > 0:
            non_null_list   = list(non_null)
            non_null_sorted = sorted(non_null_list)
            min_v = safe_str(non_null_sorted[0])
            max_v = safe_str(non_null_sorted[-1])
        else:
            min_v = ""
            max_v = ""

        # value counts
        vc = non_null.value_counts()
        if len(vc) > MAX_VALS:
            vc = vc.head(MAX_VALS)

        top_val  = safe_str(vc.index[0]) if len(vc) > 0 else ""
        denom    = total_rows if total_rows > 0 else 1
        null_pct = round(safe_float(null_count) / denom * 100, 2)

        print("  col=" + lc
              + "  null=" + str(null_count)
              + "  dist=" + str(distinct_count)
              + "  top=" + top_val[:20])

        # Profile row — all values are plain Python types
        p_row = dict()
        p_row["schema_type"]    = safe_str(schema_type)
        p_row["column_name"]    = safe_str(lc)
        p_row["original_name"]  = safe_str(lc)
        p_row["data_type"]      = "string"
        p_row["total_rows"]     = safe_int(total_rows)
        p_row["null_count"]     = safe_int(null_count)
        p_row["null_pct"]       = safe_float(null_pct)
        p_row["distinct_count"] = safe_int(distinct_count)
        p_row["min_value"]      = safe_str(min_v)
        p_row["max_value"]      = safe_str(max_v)
        p_row["top_value"]      = safe_str(top_val)
        profile_rows.append(p_row)

        vc_index  = list(vc.index)
        vc_values = list(vc.values)
        limit     = len(vc_index)

        for rank in range(limit):
            val_str = safe_str(vc_index[rank])
            cnt_int = safe_int(vc_values[rank])
            pct     = round(safe_float(cnt_int) / denom * 100, 2)

            c_row = dict()
            c_row["schema_type"]    = safe_str(schema_type)
            c_row["column_name"]    = safe_str(lc)
            c_row["original_name"]  = safe_str(lc)
            c_row["data_type"]      = "string"
            c_row["value"]          = val_str
            c_row["value_count"]    = cnt_int
            c_row["value_pct"]      = safe_float(pct)
            c_row["total_rows"]     = safe_int(total_rows)
            c_row["null_count"]     = safe_int(null_count)
            c_row["distinct_count"] = safe_int(distinct_count)
            c_row["min_value"]      = safe_str(min_v)
            c_row["max_value"]      = safe_str(max_v)
            csv_rows.append(c_row)

            if rank < TOP_N:
                v_row = dict()
                v_row["schema_type"]   = safe_str(schema_type)
                v_row["column_name"]   = safe_str(lc)
                v_row["original_name"] = safe_str(lc)
                v_row["data_type"]     = "string"
                v_row["value"]         = val_str
                v_row["value_count"]   = cnt_int
                v_row["value_pct"]     = safe_float(pct)
                v_row["value_rank"]    = safe_int(rank + 1)
                v_row["total_rows"]    = safe_int(total_rows)
                values_rows.append(v_row)

    del combined

    profile_pdf = _pd.DataFrame(profile_rows)
    values_pdf  = _pd.DataFrame(values_rows)
    csv_pdf     = _pd.DataFrame(csv_rows)

    return profile_pdf, values_pdf, csv_pdf, total_rows

print("CELL 5 DONE")


