# CELL 8 — Write Parquet to S3 using pyarrow (no spark.createDataFrame)
# ─────────────────────────────────────────────────────────────────────────────
import io
import boto3
import pandas as pd
import pyarrow as pa
import pyarrow.parquet as pq

def write_parquet_s3(df, bucket, key, int_cols, float_cols):
    """Write pandas DataFrame to S3 as Parquet using pyarrow."""
    if df is None or len(df) == 0:
        print("  SKIP (empty): " + key)
        return

    pdf = df.copy()

    # Coerce types explicitly
    for c in list(pdf.columns):
        if c in int_cols:
            pdf[c] = pd.to_numeric(
                pdf[c], errors="coerce").fillna(0).astype("int64")
        elif c in float_cols:
            pdf[c] = pd.to_numeric(
                pdf[c], errors="coerce").fillna(0.0).astype("float64")
        else:
            pdf[c] = pdf[c].fillna("").astype(str)

    # Write to buffer using pyarrow
    buf   = io.BytesIO()
    table = pa.Table.from_pandas(pdf, preserve_index=False)
    pq.write_table(table, buf)
    buf.seek(0)

    # Upload to S3
    boto3.client("s3").put_object(
        Bucket      = bucket,
        Key         = key,
        Body        = buf.read(),
        ContentType = "application/octet-stream")
    buf.close()
    print("  Written -> s3://" + bucket + "/" + key)


