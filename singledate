import pandas as pd

def make_spark_df(rows, col_names, int_cols, float_cols):
    """
    Write rows to S3 as CSV via pandas, then read back with Spark.
    This avoids createDataFrame() entirely — which triggers the
    float/column validator error on numpy types.
    """
    import io as _io
    import pandas as _pd
    import boto3 as _b3
    from pyspark.sql import functions as _F

    if len(rows) > 0:
        pdf = _pd.DataFrame(rows, columns=col_names)
    else:
        pdf = _pd.DataFrame(columns=col_names)

    # Coerce to correct pandas types
    for c in col_names:
        if c in int_cols:
            pdf[c] = _pd.to_numeric(
                pdf[c], errors="coerce").fillna(0).astype("int64")
        elif c in float_cols:
            pdf[c] = _pd.to_numeric(
                pdf[c], errors="coerce").fillna(0.0).astype("float64")
        else:
            pdf[c] = pdf[c].fillna("").astype(str)

    # Write to temp S3 location as CSV
    tmp_key   = OUTPUT_PREFIX + "tmp_spark_input/" + col_names[0] + "_tmp.csv"
    csv_bytes = pdf.to_csv(index=False).encode("utf-8")
    _b3.client("s3").put_object(
        Bucket=OUTPUT_BUCKET, Key=tmp_key,
        Body=csv_bytes, ContentType="text/csv")

    # Read back with Spark — all cols come in as string
    tmp_s3 = "s3://" + OUTPUT_BUCKET + "/" + tmp_key
    sdf    = spark.read.option("header", "true").csv(tmp_s3)

    # Cast each column to correct Spark type
    cast_list = []
    for c in col_names:
        if c in int_cols:
            cast_list.append(_F.col(c).cast("bigint").alias(c))
        elif c in float_cols:
            cast_list.append(_F.col(c).cast("double").alias(c))
        else:
            cast_list.append(_F.col(c).cast("string").alias(c))
    sdf = sdf.select(cast_list)

    # Delete temp file
    try:
        _b3.client("s3").delete_object(Bucket=OUTPUT_BUCKET, Key=tmp_key)
    except Exception:
        pass

    return sdf


