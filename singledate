def safe_rows(rows, schema):
    coerce = {
        "StringType()" : lambda v: str(v)   if v is not None else None,
        "LongType()"   : lambda v: int(v)   if v is not None else None,
        "IntegerType()": lambda v: int(v)   if v is not None else None,
        "DoubleType()" : lambda v: float(v) if v is not None else None,
    }
    return [
        {f.name: coerce.get(str(f.dataType), lambda v: v)(row.get(f.name))
         for f in schema.fields}
        for row in rows
    ]

profile_df = spark.createDataFrame(safe_rows(all_profile_rows, profile_schema), schema=profile_schema)
values_df  = spark.createDataFrame(safe_rows(all_values_rows,  values_schema),  schema=values_schema)
summary_df = spark.createDataFrame(safe_rows(all_summary_rows, summary_schema), schema=summary_schema)

