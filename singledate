# ─────────────────────────────────────────────────────────────────────────────
import boto3
from collections import defaultdict

# List all top-level folders under SOURCE_PREFIX
# Each folder = one schema type  e.g. schematype1/, schematype2/ ...
response  = boto3.client("s3").list_objects_v2(
    Bucket    = SOURCE_BUCKET,
    Prefix    = SOURCE_PREFIX,
    Delimiter = "/")

schema_folders = []
for cp in response.get("CommonPrefixes", []):
    folder = cp["Prefix"]                        # e.g. projects/.../schematype1/
    name   = folder.rstrip("/").split("/")[-1]   # e.g. schematype1
    schema_folders.append({
        "folder_prefix": folder,
        "schema_name"  : name,
    })

print("CELL 2 DONE — schema folders found: " + str(len(schema_folders)))
for sf in schema_folders:
    print("  " + sf["schema_name"] + "  ->  " + sf["folder_prefix"])


# ─────────────────────────────────────────────────────────────────────────────
# CELL 3 — For each schema folder find the JSON partition subfolder
# ─────────────────────────────────────────────────────────────────────────────
import boto3

schema_info = []   # list of {schema_name, s3_path, file_count, total_bytes}

for sf in schema_folders:
    schema_name   = sf["schema_name"]
    folder_prefix = sf["folder_prefix"]

    # List subfolders (e.g. schema_type=schematype1/)
    resp2 = boto3.client("s3").list_objects_v2(
        Bucket    = SOURCE_BUCKET,
        Prefix    = folder_prefix,
        Delimiter = "/")

    sub_prefixes = []
    for cp2 in resp2.get("CommonPrefixes", []):
        sub_prefixes.append(cp2["Prefix"])

    # Use first subfolder if exists, else use the folder itself
    if len(sub_prefixes) > 0:
        data_prefix = sub_prefixes[0]
    else:
        data_prefix = folder_prefix

    # Count JSON files and total bytes
    file_count  = 0
    total_bytes = 0
    paginator   = boto3.client("s3").get_paginator("list_objects_v2")
    for page in paginator.paginate(
            Bucket=SOURCE_BUCKET, Prefix=data_prefix):
        for obj in page.get("Contents", []):
            key = obj["Key"]
            if key.lower().endswith(".json"):
                file_count  = file_count  + 1
                total_bytes = total_bytes + int(obj["Size"])

    s3_path = "s3://" + SOURCE_BUCKET + "/" + data_prefix

    schema_info.append({
        "schema_name" : schema_name,
        "s3_path"     : s3_path,
        "file_count"  : file_count,
        "total_mb"    : round(total_bytes / 1024 / 1024, 2),
    })

    print(schema_name
          + "  path=" + s3_path
          + "  files=" + str(file_count)
          + "  mb=" + str(round(total_bytes/1024/1024, 2)))

print("CELL 3 DONE — " + str(len(schema_info)) + " schemas ready")


