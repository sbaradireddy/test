            max_v = str_keys_sorted[-1]
        else:
            min_v = ""
            max_v = ""

        denom    = total_rows
        if denom < 1:
            denom = 1
        null_pct = round(n_null / denom * 100, 2)

        profile_row = [
            str(schema_type), str(lc), str(lc), "string",
            int(total_rows), int(n_null), float(null_pct),
            int(n_distinct), str(min_v), str(max_v), str(top_val),
        ]
        profile_rows.append(profile_row)

        limit = len(vc_items)
        if limit > MAX_VALS:
            limit = MAX_VALS

        for rank in range(limit):
            val_str = str(vc_items[rank][0])
            cnt_int = int(vc_items[rank][1])
            pct     = round(cnt_int / denom * 100, 2)
            csv_row = [
                str(schema_type), str(lc), str(lc), "string",
