# ─────────────────────────────────────────────────────────────────────────────
# CELL 8 ── Build Spark DataFrames via pandas (safest conversion path)
#
# KEY FIX:
#   Instead of spark.createDataFrame(list_of_dicts, schema=...) which
#   requires exact Python type matching and fails with "got generator",
#   we first build a pandas DataFrame with explicit dtypes, then call
#   spark.createDataFrame(pandas_df) which handles all type coercion
#   internally and never raises "got generator".
# ─────────────────────────────────────────────────────────────────────────────

def rows_to_spark(rows, col_names, dtypes_map):
    """
    rows      : list of lists (one list per row)
    col_names : list of column name strings
    dtypes_map: dict of col_name → pandas dtype string
                e.g. {"total_rows": "int64", "null_pct": "float64"}

    Builds a pandas DataFrame with explicit dtypes,
    then converts to Spark — bypasses all row-dict conversion issues.
    """
    if not rows:
        # Return empty pandas DF with correct columns
        pdf = pd.DataFrame(columns=col_names)
    else:
        pdf = pd.DataFrame(rows, columns=col_names)

    # Apply explicit dtypes
    for col, dtype in dtypes_map.items():
        if col in pdf.columns:
            try:
                if dtype == "str":
                    pdf[col] = pdf[col].fillna("").astype(str)
                elif dtype == "int64":
                    pdf[col] = pd.to_numeric(
                        pdf[col], errors="coerce").fillna(0).astype("int64")
                elif dtype == "float64":
                    pdf[col] = pd.to_numeric(
                        pdf[col], errors="coerce").fillna(0.0).astype("float64")
            except Exception as e:
                print(f"  ⚠️  dtype coerce [{col}→{dtype}]: {e}")

    return spark.createDataFrame(pdf)


