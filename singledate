# STEP 7 — Write Parquet to S3 using pyarrow (zero Spark)
# ==============================================================================
def write_parquet(df, bucket, key, int_cols, float_cols):
    if len(df) == 0:
        return
    pdf = df.copy()
    for c in list(pdf.columns):
        if c in int_cols:
            pdf[c] = pd.to_numeric(
                pdf[c], errors="coerce").fillna(0).astype("int64")
        elif c in float_cols:
            pdf[c] = pd.to_numeric(
                pdf[c], errors="coerce").fillna(0.0).astype("float64")
        else:
            pdf[c] = pdf[c].fillna("").astype(str)

    buf   = io.BytesIO()
    table = pa.Table.from_pandas(pdf, preserve_index=False)
    pq.write_table(table, buf)
    buf.seek(0)
    s3_client.put_object(
        Bucket=bucket, Key=key,
        Body=buf.read(),
        ContentType="application/octet-stream")
    buf.close()
    print("Parquet written -> s3://" + bucket + "/" + key)


base = OUTPUT_PREFIX + "quicksight_tables"

PROFILE_INT   = ["total_rows", "null_count", "distinct_count"]
PROFILE_FLOAT = ["null_pct"]
VALUES_INT    = ["value_count", "value_rank", "total_rows"]
VALUES_FLOAT  = ["value_pct"]
