ARRAY_IDX_RE = re.compile(r"^(.+?)_\d+_(.+)$")

def logical_name(col_name):
    m = ARRAY_IDX_RE.match(str(col_name))
    return f"{m.group(1)}_{m.group(2)}" if m else str(col_name)

def canonical_type(spark_field_type):
    t = str(spark_field_type).lower()
    t = re.sub(r"type\b", "", t).strip()
    t = re.sub(r"\(.*?\)", "", t).strip()
    return t

