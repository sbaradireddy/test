base_s3 = "s3://" + OUTPUT_BUCKET + "/" + OUTPUT_PREFIX + "quicksight_tables"

def register_table(name, path, col_defs, pk=None):
    cols = []
    for col_name, col_type in col_defs:
        if col_name == pk:
            continue
        cols.append({"Name": col_name, "Type": col_type})

    part_keys = [{"Name": pk, "Type": "string"}] if pk else []

    tbl = {
        "Name": name,
        "StorageDescriptor": {
            "Columns": cols, "Location": path,
            "InputFormat": ("org.apache.hadoop.hive.ql.io"
                            ".parquet.MapredParquetInputFormat"),
            "OutputFormat": ("org.apache.hadoop.hive.ql.io"
                             ".parquet.MapredParquetOutputFormat"),
            "SerdeInfo": {
                "SerializationLibrary": ("org.apache.hadoop.hive.ql.io"
                                         ".parquet.serde.ParquetHiveSerDe"),
                "Parameters": {"serialization.format": "1"},
            },
            "Compressed": False, "StoredAsSubDirectories": True,
        },
        "PartitionKeys": part_keys,
        "TableType": "EXTERNAL_TABLE",
        "Parameters": {"classification": "parquet", "EXTERNAL": "TRUE"},
    }
    try:
        glue_client.create_table(DatabaseName=glue_db, TableInput=tbl)
        print("Created " + glue_db + "." + name)
    except glue_client.exceptions.AlreadyExistsException:
        glue_client.update_table(DatabaseName=glue_db, TableInput=tbl)
        print("Updated " + glue_db + "." + name)
    try:
        boto3.client("athena").start_query_execution(
            QueryString="MSCK REPAIR TABLE " + glue_db + "." + name,
            ResultConfiguration={
                "OutputLocation": "s3://" + OUTPUT_BUCKET
                                  + "/athena-query-results/"})
        print("Partitions repaired: " + name)
    except Exception as e:
        print("Partition repair skipped: " + str(e))


register_table(
    "schema_column_profile", base_s3 + "/schema_column_profile/",
    [("schema_type","string"),("column_name","string"),
     ("original_name","string"),("data_type","string"),
