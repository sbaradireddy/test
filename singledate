# ─────────────────────────────────────────────────────────────────────────────
# CELL 2 ── List files
# ─────────────────────────────────────────────────────────────────────────────
files_on_date = []
paginator = s3c.get_paginator("list_objects_v2")

for page in paginator.paginate(Bucket=SOURCE_BUCKET, Prefix=SOURCE_PREFIX):
    for obj in page.get("Contents", []):
        key = obj["Key"]
        if not key.lower().endswith(".parquet"):
            continue
        parts = key[len(SOURCE_PREFIX):].strip("/").split("/")
        if len(parts) < 3:
            continue
        date_folder = parts[0]
        if date_folder < DATE_FROM or date_folder > DATE_TO:
            continue
        filename = parts[-1]
        stem     = filename.rsplit(".parquet", 1)[0]
        m        = re.match(r"^(SchemaType\d+)", stem, re.IGNORECASE)
        st       = m.group(1) if m else stem
        files_on_date.append({
            "s3_key"     : key,
            "s3_uri"     : f"s3://{SOURCE_BUCKET}/{key}",
            "schema_type": st,
            "filename"   : filename,
            "size_bytes" : obj["Size"],
            "date_folder": date_folder,
        })

by_schema    = defaultdict(list)
for f in files_on_date:
    by_schema[f["schema_type"]].append(f)
schema_types = sorted(by_schema.keys())

