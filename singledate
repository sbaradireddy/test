# CELL 8 — Write Parquet to S3 using pyarrow (NO Spark createDataFrame)
# ─────────────────────────────────────────────────────────────────────────────
import io
import boto3
import pandas as pd
import pyarrow as pa
import pyarrow.parquet as pq

def write_parquet_to_s3(pdf, bucket, key, int_cols, float_cols, str_cols):
    """
    Write a pandas DataFrame to S3 as Parquet using pyarrow directly.
    No Spark createDataFrame — avoids all column validator errors.
    """
    import io as _io
    import boto3 as _b3
    import pandas as _pd
    import pyarrow as _pa
    import pyarrow.parquet as _pq

    # Coerce types
    for c in list(pdf.columns):
        if c in int_cols:
            pdf[c] = _pd.to_numeric(
                pdf[c], errors="coerce").fillna(0).astype("int64")
        elif c in float_cols:
            pdf[c] = _pd.to_numeric(
                pdf[c], errors="coerce").fillna(0.0).astype("float64")
        else:
            pdf[c] = pdf[c].fillna("").astype(str)

    # Write to in-memory buffer
    buf   = _io.BytesIO()
    table = _pa.Table.from_pandas(pdf, preserve_index=False)
    _pq.write_table(table, buf)
    buf.seek(0)

    # Upload to S3
    _b3.client("s3").put_object(
        Bucket=bucket, Key=key,
        Body=buf.read(),
        ContentType="application/octet-stream")
    buf.close()
    print("Written -> s3://" + bucket + "/" + key)


