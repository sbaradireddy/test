# ─────────────────────────────────────────────────────────────────────────────
# CELL 4 ── Helpers
# ─────────────────────────────────────────────────────────────────────────────
_ARRAY_RE = re.compile(r"^(.+?)_\d+_(.+)$")

def logical_name(col):
    m = _ARRAY_RE.match(str(col))
    return f"{m.group(1)}_{m.group(2)}" if m else str(col)

def canonical_type(t):
    t = str(t).lower()
    t = re.sub(r"type\b", "", t).strip()
    t = re.sub(r"\(.*?\)", "", t).strip()
    return t

def read_s3_parquet_pandas(bucket, key):
    buf = io.BytesIO(
        boto3.resource("s3").Object(bucket, key).get()["Body"].read()
    )
    df = pq.read_table(buf).to_pandas()
    del buf
    return df

print("✅ CELL 4 DONE")


# ─────────────────────────────────────────────────────────────────────────────
# CELL 5 ── Wide analyser (pure pandas)
# ─────────────────────────────────────────────────────────────────────────────
def analyse_wide(entries, schema_type):
    freq       = defaultdict(lambda: defaultdict(int))
    null_cnt   = defaultdict(int)
    total_rows = 0

    for i, entry in enumerate(entries):
        try:
            df = read_s3_parquet_pandas(SOURCE_BUCKET, entry["s3_key"])
            df = df.astype(object).where(df.notna(), other=None)
            n  = len(df)
            total_rows += n
            print(f"    [{i+1}/{len(entries)}] "
                  f"{entry['filename']}  rows={n} cols={len(df.columns)}")

            for col in df.columns:
                lc = logical_name(col)
                for val in df[col]:
                    if val is None or (isinstance(val, float) and np.isnan(val)):
                        null_cnt[lc] += 1
                    else:
                        freq[lc][str(val)] += 1
            del df
        except Exception as e:
            print(f"    ⚠️  {entry['filename']}: {e}")

    # Build output as a list of plain Python dicts
    rows_csv     = []
    rows_profile = []
    rows_values  = []

    for lc in sorted(freq.keys()):
        vc         = freq[lc]
        n_null     = int(null_cnt.get(lc, 0))
        n_distinct = int(len(vc))
        sorted_vc  = sorted(vc.items(), key=lambda x: -x[1])
        top_val    = str(sorted_vc[0][0]) if sorted_vc else ""
        str_keys   = [str(k) for k, _ in sorted_vc]
        min_v      = str(min(str_keys)) if str_keys else ""
        max_v      = str(max(str_keys)) if str_keys else ""
        null_pct   = round(n_null / max(total_rows, 1) * 100, 2)

        rows_profile.append([
            str(schema_type), str(lc), str(lc), "string",
            int(total_rows), n_null, float(null_pct),
            n_distinct, min_v, max_v, top_val,
        ])

        for rank, (val, cnt) in enumerate(sorted_vc[:MAX_VALS], start=1):
            pct = round(int(cnt) / max(total_rows, 1) * 100, 2)
            rows_csv.append([
                str(schema_type), str(lc), str(lc), "string",
                str(val), int(cnt), float(pct),
                int(total_rows), n_null, n_distinct, min_v, max_v,
            ])
            if rank <= TOP_N:
                rows_values.append([
                    str(schema_type), str(lc), str(lc), "string",
                    str(val), int(cnt), float(pct),
                    int(rank), int(total_rows),
                ])

    return rows_profile, rows_values, rows_csv, int(total_rows)

print("✅ CELL 5 DONE")


# ─────────────────────────────────────────────────────────────────────────────
# CELL 6 ── Narrow analyser (Spark)
# ─────────────────────────────────────────────────────────────────────────────
def analyse_narrow(df, schema_type, total_rows):
    rows_profile = []
    rows_values  = []
    rows_csv     = []

    for field in df.schema.fields:
        col_name = str(field.name)
        if col_name.startswith("_"):
            continue
        col_type = canonical_type(field.dataType)

        null_count = 0
        distinct_count = 0
        min_v = ""
        max_v = ""
        top_vals = []

        try:
            # Use df[col_name] instead of F.col() to avoid any type issues
            col_df = df.select(df[col_name].cast("string").alias("v"))
        except Exception as e:
            print(f"    ⚠️  select failed [{col_name}]: {e}")
            continue

        try:
            null_count = col_df.filter(F.col("v").isNull()).count()
        except Exception:
            pass
        try:
            distinct_count = col_df.dropna().distinct().count()
        except Exception:
            pass
        try:
            st = col_df.dropna().agg(
                F.min("v").alias("mn"),
                F.max("v").alias("mx"),
            ).collect()[0]
            min_v = str(st["mn"]) if st["mn"] is not None else ""
            max_v = str(st["mx"]) if st["mx"] is not None else ""
        except Exception:
            pass
        try:
            top_vals = (
                col_df.dropna()
                .groupBy("v").agg(F.count("*").alias("c"))
                .orderBy(F.col("c").desc())
                .limit(MAX_VALS)
                .collect()
            )
        except Exception as e:
            print(f"    ⚠️  freq [{col_name}]: {e}")

        top_val  = str(top_vals[0]["v"]) if top_vals else ""
        null_pct = round(null_count / max(total_rows, 1) * 100, 2)
        print(f"    ✓ {col_name:<50}  "
              f"null={null_count} dist={distinct_count} top='{top_val[:20]}'")

        rows_profile.append([
            str(schema_type), str(col_name), str(col_name), str(col_type),
            int(total_rows), int(null_count), float(null_pct),
            int(distinct_count), str(min_v), str(max_v), str(top_val),
        ])

        for rank, row in enumerate(top_vals[:TOP_N], start=1):
            val_str = str(row["v"]) if row["v"] is not None else ""
            val_cnt = int(row["c"])
            pct     = round(val_cnt / max(total_rows, 1) * 100, 2)
            rows_csv.append([
                str(schema_type), str(col_name), str(col_name), str(col_type),
                val_str, val_cnt, float(pct),
                int(total_rows), int(null_count),
                int(distinct_count), str(min_v), str(max_v),
            ])
            rows_values.append([
                str(schema_type), str(col_name), str(col_name), str(col_type),
                val_str, val_cnt, float(pct), int(rank), int(total_rows),
            ])

    return rows_profile, rows_values, rows_csv

