# Profile — one file per schema_type
if len(final_profile) > 0:
    st_list = list(final_profile["schema_type"].unique())
    for st in st_list:
        subset = final_profile[
            final_profile["schema_type"] == st].copy()
        key = (base + "/schema_column_profile/"
               + "schema_type=" + st + "/data.parquet")
        write_parquet(subset, OUTPUT_BUCKET, key, PROFILE_INT, PROFILE_FLOAT)

# Values — one file per schema_type
if len(final_values) > 0:
    st_list = list(final_values["schema_type"].unique())
    for st in st_list:
        subset = final_values[
            final_values["schema_type"] == st].copy()
        key = (base + "/schema_column_values/"
               + "schema_type=" + st + "/data.parquet")
        write_parquet(subset, OUTPUT_BUCKET, key, VALUES_INT, VALUES_FLOAT)

# Summary
if len(final_summary) > 0:
    key = base + "/schema_summary/data.parquet"
    write_parquet(final_summary.copy(), OUTPUT_BUCKET, key, SUMMARY_INT, [])

print("PARQUET WRITE DONE")


