# ── Safe min/max that cannot be shadowed by PySpark ──────────────────────────
# PySpark imports its own max(col) and min(col) into the namespace.
# These wrappers call the builtins explicitly via __builtins__ so they
# always work on plain Python lists/values regardless of what PySpark does.

def py_min(lst):
    """Python built-in min on a list — never shadowed by PySpark."""
    result = None
    first  = True
    for item in lst:
        if first:
            result = item
            first  = False
        elif item < result:
            result = item
    return result

def py_max(lst):
    """Python built-in max on a list — never shadowed by PySpark."""
    result = None
    first  = True
    for item in lst:
        if first:
            result = item
            first  = False
        elif item > result:
            result = item
    return result

