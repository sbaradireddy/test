def safe_rows(rows, schema):
    """
    FIX: Convert each row dict to a NEW plain dict matching the schema exactly.
    Uses an explicit for-loop — NOT a dict-comprehension inside a
    list-comprehension, which can produce a generator object in some
    PySpark versions and cause 'got generator' TypeError.
    """
    COERCE = {
        "StringType()" : lambda v: str(v)   if v is not None else None,
        "LongType()"   : lambda v: int(v)   if v is not None else None,
        "IntegerType()": lambda v: int(v)   if v is not None else None,
        "DoubleType()" : lambda v: float(v) if v is not None else None,
        "FloatType()"  : lambda v: float(v) if v is not None else None,
        "BooleanType()": lambda v: bool(v)  if v is not None else None,
    }
    result = []                              # plain list
    for row in rows:
        new_row = {}                         # plain dict — NOT a generator
        for field in schema.fields:
            raw    = row.get(field.name)     # get raw value
            coerce = COERCE.get(str(field.dataType), lambda v: v)
            new_row[field.name] = coerce(raw)   # explicit key = value
        result.append(new_row)               # append plain dict
    return result                            # return plain list


