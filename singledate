        entry = entries[i]
        try:
            body  = _boto3.resource("s3").Object(
                SOURCE_BUCKET, entry["s3_key"]).get()["Body"].read()
            buf   = _io.BytesIO(body)
            df    = _pq.read_table(buf).to_pandas()
            del buf, body
            n          = int(len(df))
            total_rows = total_rows + n
            col_list   = list(df.columns)
            print("  [" + str(i+1) + "/" + str(entry_count) + "] "
                  + entry["filename"]
                  + "  rows=" + str(n)
                  + "  cols=" + str(len(col_list)))

            for col in col_list:
                lc         = logical_name(col)
                col_values = list(df[col])
                for val in col_values:
                    is_null = False
                    if val is None:
                        is_null = True
                    elif isinstance(val, float):
                        if _np.isnan(val):
                            is_null = True
                    if is_null:
                        null_cnt[lc] = null_cnt[lc] + 1
                    else:
                        val_str = str(val)
                        freq[lc][val_str] = freq[lc][val_str] + 1
            del df, col_values
        except Exception as e:
            print("  SKIP " + entry["filename"] + ": " + str(e))

    profile_rows = []
    values_rows  = []
    csv_rows     = []

    lc_list = sorted(freq.keys())
