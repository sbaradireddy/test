# ─────────────────────────────────────────────────────────────────────────────
# CELL 5 — Core analysis function
#           Reads JSON, profiles every column, returns pandas DataFrames
# ─────────────────────────────────────────────────────────────────────────────
from pyspark.sql import functions as F
import pandas as pd

def analyse_schema_json(schema_name, s3_path, max_vals, top_n):
    """
    Read all JSON files for one schema type.
    For each column compute:
      - null count, distinct count, min, max, top value
      - top N value frequencies
    Returns three pandas DataFrames: profile_df, values_df, csv_df
    """
    print("  Reading: " + s3_path)

    # Read all JSON files in this path
    df         = spark.read.json(s3_path)
    total_rows = df.count()
    col_list   = [str(c) for c in df.columns]

    print("  rows=" + str(total_rows) + "  cols=" + str(len(col_list)))

    profile_rows = []
    values_rows  = []
    csv_rows     = []

    for col_name in col_list:
        # Cast to string so all types are handled uniformly
        col_df = df.select(
            F.col("`" + col_name + "`").cast("string").alias("v"))

        # Null count
        null_count = col_df.filter(
            F.col("v").isNull() | (F.col("v") == "")
        ).count()

        # Non-null series
        non_null_df = col_df.filter(
            F.col("v").isNotNull() & (F.col("v") != ""))

        # Distinct count
        distinct_count = non_null_df.distinct().count()

        # Min and max
        stats = non_null_df.agg(
            F.min("v").alias("mn"),
            F.max("v").alias("mx")
        ).collect()

        min_val = ""
        max_val = ""
        if len(stats) > 0 and stats[0]["mn"] is not None:
            min_val = str(stats[0]["mn"])
            max_val = str(stats[0]["mx"])

        # Top N value frequencies
        top_rows = (
            non_null_df
            .groupBy("v")
            .agg(F.count("*").alias("cnt"))
            .orderBy(F.col("cnt").desc())
            .limit(max_vals)
            .collect()
        )

        top_val  = str(top_rows[0]["v"])   if top_rows else ""
        denom    = total_rows if total_rows > 0 else 1
        null_pct = round(null_count / denom * 100, 2)

        print("    col=" + col_name
              + "  null=" + str(null_count)
              + "  dist=" + str(distinct_count)
              + "  top=" + top_val[:25])

        # Profile row
        profile_rows.append({
            "schema_type"   : str(schema_name),
            "column_name"   : str(col_name),
            "data_type"     : "string",
            "total_rows"    : int(total_rows),
            "null_count"    : int(null_count),
            "null_pct"      : float(null_pct),
            "distinct_count": int(distinct_count),
            "min_value"     : str(min_val),
            "max_value"     : str(max_val),
            "top_value"     : str(top_val),
        })

        # Value + CSV rows
        for rank in range(len(top_rows)):
            row     = top_rows[rank]
            val_str = str(row["v"])
            cnt     = int(row["cnt"])
            pct     = round(cnt / denom * 100, 2)

            csv_rows.append({
                "schema_type"   : str(schema_name),
                "column_name"   : str(col_name),
                "data_type"     : "string",
                "value"         : val_str,
                "value_count"   : cnt,
                "value_pct"     : float(pct),
                "total_rows"    : int(total_rows),
                "null_count"    : int(null_count),
                "distinct_count": int(distinct_count),
                "min_value"     : str(min_val),
                "max_value"     : str(max_val),
            })

            if rank < top_n:
                values_rows.append({
                    "schema_type" : str(schema_name),
                    "column_name" : str(col_name),
                    "data_type"   : "string",
                    "value"       : val_str,
                    "value_count" : cnt,
                    "value_pct"   : float(pct),
                    "value_rank"  : int(rank + 1),
                    "total_rows"  : int(total_rows),
                })

    del df

    return (pd.DataFrame(profile_rows),
            pd.DataFrame(values_rows),
            pd.DataFrame(csv_rows),
            int(total_rows))

print("CELL 5 DONE — analyse_schema_json defined")


# ─────────────────────────────────────────────────────────────────────────────
# CELL 6 — Run analysis on ALL schema types
# ─────────────────────────────────────────────────────────────────────────────
import boto3
import pandas as pd
from datetime import datetime

all_profile_dfs  = []
all_values_dfs   = []
all_summary_rows = []

s3_main = boto3.client("s3")

for info in schema_info:
    schema_name = info["schema_name"]
    s3_path     = info["s3_path"]

    print("\n" + "="*55)
    print("SCHEMA = " + schema_name)
    print("PATH   = " + s3_path)
    print("="*55)

    try:
        p_df, v_df, c_df, total_rows = analyse_schema_json(
            schema_name, s3_path, MAX_VALS, TOP_N)
    except Exception as e:
        print("ERROR on " + schema_name + ": " + str(e))
        continue

    if len(p_df) > 0:
        all_profile_dfs.append(p_df)
    if len(v_df) > 0:
        all_values_dfs.append(v_df)

    # ── Save CSV immediately ──────────────────────────────────────────────────
    if len(c_df) > 0:
        c_sorted = c_df.sort_values(
            ["column_name", "value_count"],
            ascending=[True, False])
        csv_key = (OUTPUT_PREFIX + "csv_analysis/"
                   + schema_name + "_column_value_mapping.csv")
        s3_main.put_object(
            Bucket      = OUTPUT_BUCKET,
            Key         = csv_key,
            Body        = c_sorted.to_csv(index=False).encode("utf-8"),
            ContentType = "text/csv")
        print("CSV saved  rows=" + str(len(c_sorted))
              + "  key=" + csv_key)
        print(c_sorted.head(5).to_string(index=False))

    # ── Summary row ───────────────────────────────────────────────────────────
    unique_cols = {}
    for idx in range(len(p_df)):
        unique_cols[p_df.iloc[idx]["column_name"]] = 1

    all_summary_rows.append({
        "schema_type"  : str(schema_name),
        "total_columns": int(len(unique_cols)),
        "total_rows"   : int(total_rows),
        "file_count"   : int(info["file_count"]),
        "total_mb"     : float(info["total_mb"]),
        "s3_path"      : str(s3_path),
        "analysed_at"  : str(datetime.utcnow().isoformat() + "Z"),
    })

