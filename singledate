def register(name, path, schema, pk=None):
    TYPES = {"StringType()":"string","LongType()":"bigint",
             "IntegerType()":"int","DoubleType()":"double"}
    cols  = [{"Name":f.name,"Type":TYPES.get(str(f.dataType),"string")}
             for f in schema.fields if f.name != pk]
    tbl   = {
        "Name": name,
        "StorageDescriptor": {
            "Columns": cols, "Location": path,
            "InputFormat" : "org.apache.hadoop.hive.ql.io.parquet.MapredParquetInputFormat",
            "OutputFormat": "org.apache.hadoop.hive.ql.io.parquet.MapredParquetOutputFormat",
            "SerdeInfo"   : {"SerializationLibrary":
                "org.apache.hadoop.hive.ql.io.parquet.serde.ParquetHiveSerDe",
                "Parameters": {"serialization.format":"1"}},
            "Compressed": False, "StoredAsSubDirectories": True,
        },
        "PartitionKeys": [{"Name":pk,"Type":"string"}] if pk else [],
        "TableType"    : "EXTERNAL_TABLE",
        "Parameters"   : {"classification":"parquet","EXTERNAL":"TRUE"},
    }
    try:
        glue_client.create_table(DatabaseName=glue_db, TableInput=tbl)
        print(f"  ✅ Created {glue_db}.{name}")
    except glue_client.exceptions.AlreadyExistsException:
        glue_client.update_table(DatabaseName=glue_db, TableInput=tbl)
        print(f"  ✅ Updated {glue_db}.{name}")

register("schema_column_profile", f"{base}/schema_column_profile/", profile_schema, "schema_type")
register("schema_column_values",  f"{base}/schema_column_values/",  values_schema,  "schema_type")
register("schema_summary",        f"{base}/schema_summary/",        summary_schema)

