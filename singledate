# CELL 4 ── Helpers
# ─────────────────────────────────────────────────────────────────────────────
ARRAY_IDX_RE = re.compile(r"^(.+?)_\d+_(.+)$")

def logical_name(col_name: str) -> str:
    m = ARRAY_IDX_RE.match(col_name)
    return f"{m.group(1)}_{m.group(2)}" if m else col_name

def canonical_type(spark_field_type) -> str:
    t = str(spark_field_type).lower()
    t = re.sub(r"type\b", "", t).strip()
    t = re.sub(r"\(.*?\)", "", t).strip()
    return t

print("✅ CELL 4 DONE — helpers ready")


# ─────────────────────────────────────────────────────────────────────────────
# CELL 5 ── WIDE schema analyser — pure pandas, no Spark at all
# ─────────────────────────────────────────────────────────────────────────────

def analyse_wide_pandas(entries, schema_type, max_val=200, top_n=50):
    freq     = defaultdict(lambda: defaultdict(int))
    null_cnt = defaultdict(int)
    total_rows = 0

    for i, entry in enumerate(entries):
        try:
            obj = s3_res.Object(SOURCE_BUCKET, entry["s3_key"])
            buf = io.BytesIO(obj.get()["Body"].read())
            df  = pq.read_table(buf).to_pandas().astype(str)
            df.replace({"None": pd.NA, "nan": pd.NA, "<NA>": pd.NA}, inplace=True)
            buf = None   # free memory

            n   = len(df)
            total_rows += n
            print(f"    File {i+1}/{len(entries)}: {entry['filename']}  "
                  f"rows={n}  cols={len(df.columns)}")

            # melt: all columns → (col_name, value)
            melted = df.melt(var_name="col_name", value_name="value")
            melted["logical"] = melted["col_name"].map(logical_name)

            null_mask = melted["value"].isna()
            for lc, cnt in melted[null_mask].groupby("logical").size().items():
                null_cnt[lc] += int(cnt)

            non_null = melted[~null_mask]
            for (lc, val), cnt in non_null.groupby(
                    ["logical", "value"], sort=False).size().items():
                freq[lc][str(val)] += int(cnt)

            del df, melted, non_null
        except Exception as e:
            print(f"    ⚠️  {entry['filename']}: {e}")

    # Build output rows
    profile_rows = []
    values_rows  = []
    csv_rows     = []

    for lc in sorted(freq.keys()):
        vc          = freq[lc]
        n_null      = null_cnt.get(lc, 0)
        n_distinct  = len(vc)
        sorted_vals = sorted(vc.items(), key=lambda x: -x[1])
        top_value   = sorted_vals[0][0] if sorted_vals else ""
        str_keys    = [str(v) for v, _ in sorted_vals]
        min_val     = min(str_keys) if str_keys else ""
        max_val_s   = max(str_keys) if str_keys else ""
        null_pct    = round((n_null / max(total_rows, 1)) * 100, 2)

        profile_rows.append({
            "schema_type"   : str(schema_type),
            "column_name"   : str(lc),
            "original_name" : str(lc),
            "data_type"     : "string",
            "total_rows"    : int(total_rows),
            "null_count"    : int(n_null),
            "null_pct"      : null_pct,
            "distinct_count": int(n_distinct),
            "min_value"     : min_val,
            "max_value"     : max_val_s,
            "top_value"     : str(top_value),
        })

        for rank, (val, cnt) in enumerate(sorted_vals[:max_val], start=1):
            pct = round((cnt / max(total_rows, 1)) * 100, 2)
            row_base = {
                "schema_type"   : str(schema_type),
                "column_name"   : str(lc),
                "original_name" : str(lc),
                "data_type"     : "string",
                "value"         : str(val),
                "value_count"   : int(cnt),
                "value_pct"     : pct,
                "total_rows"    : int(total_rows),
                "null_count"    : int(n_null),
                "distinct_count": int(n_distinct),
                "min_value"     : min_val,
                "max_value"     : max_val_s,
            }
            csv_rows.append(row_base)
            if rank <= top_n:
                values_rows.append({**row_base, "value_rank": rank})

    return profile_rows, values_rows, csv_rows, total_rows


# ─────────────────────────────────────────────────────────────────────────────
# CELL 6 ── NARROW schema analyser (Spark)
# ─────────────────────────────────────────────────────────────────────────────

def analyse_narrow_spark(df, schema_type, total_rows, max_val=200, top_n=50):
    data_fields = [
        (f.name, f.dataType)
        for f in df.schema.fields
        if not f.name.startswith("_")
    ]
    profile_rows = []
    values_rows  = []
    csv_rows     = []

    for col_name, col_dtype in data_fields:
        col_type_str = canonical_type(col_dtype)
        try:
            col_df = df.select(
                F.col(f"`{col_name}`").cast("string").alias("value")
            )
        except Exception as e:
            print(f"    ⚠️  select failed [{col_name}]: {e}")
            continue

        null_count     = 0
        distinct_count = 0
        min_val        = ""
        max_val_s      = ""
        top_values     = []

        try:
            null_count = col_df.filter(F.col("value").isNull()).count()
        except Exception:
            pass
        try:
            distinct_count = col_df.dropna().distinct().count()
        except Exception:
            pass
        try:
            stats = col_df.dropna().agg(
                F.min("value").alias("mn"),
                F.max("value").alias("mx"),
            ).collect()[0]
            min_val   = str(stats["mn"]) if stats["mn"] else ""
            max_val_s = str(stats["mx"]) if stats["mx"] else ""
        except Exception:
            pass
        try:
            top_values = (
                col_df.dropna()
                .groupBy("value")
                .agg(F.count("*").alias("cnt"))
                .orderBy(F.col("cnt").desc())
                .limit(max_val)
                .collect()
            )
        except Exception as e:
            print(f"    ⚠️  freq failed [{col_name}]: {e}")

        top_value = str(top_values[0]["value"]) if top_values else ""
        null_pct  = round((null_count / max(total_rows, 1)) * 100, 2)
        print(f"    ✓ {col_name:<50} null={null_count}  dist={distinct_count}")

        profile_rows.append({
            "schema_type"   : str(schema_type),
            "column_name"   : str(col_name),
            "original_name" : str(col_name),
            "data_type"     : str(col_type_str),
            "total_rows"    : int(total_rows),
            "null_count"    : int(null_count),
            "null_pct"      : null_pct,
            "distinct_count": int(distinct_count),
            "min_value"     : str(min_val),
            "max_value"     : str(max_val_s),
            "top_value"     : str(top_value),
        })

        for rank, row in enumerate(top_values[:top_n], start=1):
            val_str = str(row["value"]) if row["value"] else ""
            val_cnt = int(row["cnt"])
            pct     = round((val_cnt / max(total_rows, 1)) * 100, 2)
            base    = {
                "schema_type"   : str(schema_type),
                "column_name"   : str(col_name),
                "original_name" : str(col_name),
                "data_type"     : str(col_type_str),
                "value"         : val_str,
                "value_count"   : val_cnt,
                "value_pct"     : pct,
                "total_rows"    : int(total_rows),
                "null_count"    : int(null_count),
                "distinct_count": int(distinct_count),
                "min_value"     : str(min_val),
                "max_value"     : str(max_val_s),
            }
            csv_rows.append(base)
            values_rows.append({**base, "value_rank": rank})

    return profile_rows, values_rows, csv_rows


