def register_table(name, path, col_names, dtypes_map, pk=None):
    TYPE_MAP = {"str":"string","int64":"bigint","float64":"double"}
    cols = []
    for c in col_names:
        if c == pk:
            continue
        glue_type = TYPE_MAP.get(dtypes_map.get(c, "str"), "string")
        cols.append({"Name": c, "Type": glue_type})

    part_keys = [{"Name": pk, "Type": "string"}] if pk else []

    tbl = {
        "Name": name,
        "StorageDescriptor": {
            "Columns": cols, "Location": path,
            "InputFormat": ("org.apache.hadoop.hive.ql.io"
                            ".parquet.MapredParquetInputFormat"),
            "OutputFormat": ("org.apache.hadoop.hive.ql.io"
                             ".parquet.MapredParquetOutputFormat"),
            "SerdeInfo": {
                "SerializationLibrary": (
                    "org.apache.hadoop.hive.ql.io"
                    ".parquet.serde.ParquetHiveSerDe"),
                "Parameters": {"serialization.format": "1"},
            },
            "Compressed": False,
            "StoredAsSubDirectories": True,
        },
        "PartitionKeys": part_keys,
        "TableType": "EXTERNAL_TABLE",
        "Parameters": {"classification": "parquet", "EXTERNAL": "TRUE"},
    }
    try:
        glue_client.create_table(DatabaseName=glue_db, TableInput=tbl)
        print(f"  ✅ Created  {glue_db}.{name}")
    except glue_client.exceptions.AlreadyExistsException:
        glue_client.update_table(DatabaseName=glue_db, TableInput=tbl)
        print(f"  ✅ Updated  {glue_db}.{name}")
    try:
        boto3.client("athena").start_query_execution(
            QueryString=f"MSCK REPAIR TABLE {glue_db}.{name}",
            ResultConfiguration={
                "OutputLocation":
                    f"s3://{OUTPUT_BUCKET}/athena-query-results/"},
        )
        print(f"     Partition repair triggered")
    except Exception as e:
        print(f"     Partition repair skipped: {e}")


register_table("schema_column_profile",
