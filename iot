def canonical_type(spark_field_type) -> str:
    """Safe canonical type string from a Spark DataType object."""
    t = str(spark_field_type).lower()
    t = re.sub(r"type\b", "", t).strip()
    t = re.sub(r"\(.*?\)", "", t).strip()
    return t


def is_simple_type(spark_field_type) -> bool:
    """
    Returns True if the column type is a scalar that can be safely
    cast to string and used in groupBy/min/max.
    Complex types (ArrayType, MapType, StructType) return False.
    """
    return not isinstance(
        spark_field_type,
        (ArrayType, MapType, T.StructType)
    )


def safe_string_col(col_name: str, field_type) -> "Column":
    """
    FIX FOR: "argument 'col' should be a Column or str, got float"

    Always returns a Column object — never a raw Python value.
    For complex types (array/map/struct) we use to_json() so they
    can still be stored as a string representation.
    For all scalar types we use .cast("string").
    """
    # Ensure col_name is truly a string (guards against float column names)
    col_name = str(col_name)

    if isinstance(field_type, (ArrayType, MapType, T.StructType)):
        # to_json converts complex types to a JSON string safely
        return F.to_json(F.col(col_name)).alias(col_name)
    else:
        return F.col(col_name).cast("string").alias(col_name)


def safe_col_ref(col_name) -> str:
    """
    FIX: Guarantee col_name is a plain Python str before passing
    to F.col(), df.select(), df.filter() etc.
    PySpark raises TypeError if you pass a float or None here.
    """
    if col_name is None:
        raise ValueError("col_name is None — check schema field iteration")
    return str(col_name)


