#              b) Per column: collect all distinct values + counts
#              c) Write  CSV value-mapping report
# ─────────────────────────────────────────────────────────────────────────────

# Accumulators for QuickSight tables (populated in the loop below)
all_profile_rows = []    # schema_column_profile
all_values_rows  = []    # schema_column_values
all_summary_rows = []    # schema_summary

MAX_VAL  = CONFIG["max_values_per_column"]
TOP_N    = CONFIG["top_n_values_quicksight"]

for st in schema_types:
    entries = by_schema[st]
    print(f"\n{'═'*62}")
    print(f"  Processing: {st}  ({len(entries)} files)")
    print(f"{'═'*62}")

    # ── 5a: Load and union all files for this schema type ──────────────────
    dfs = []
    for entry in entries:
        try:
            df_part = spark.read.parquet(entry["s3_uri"])
            df_part = df_part \
                .withColumn("_date", F.lit(entry["date_folder"])) \
                .withColumn("_time", F.lit(entry["time_folder"]))
            dfs.append(df_part)
        except Exception as e:
            print(f"  ⚠️  Skip {entry['s3_uri']}: {e}")
            continue

    if not dfs:
        print(f"  ⚠️  No data loaded for {st}")
        continue

    df = dfs[0]
    for dfi in dfs[1:]:
        df = df.unionByName(dfi, allowMissingColumns=True)

    total_rows = df.count()
    print(f"  Total rows : {total_rows:,}")

    # ── 5b: Get column names and types (exclude internal _date/_time cols) ──
    data_columns = [
        (f.name, canonical_type(f.dataType))
        for f in df.schema.fields
        if not f.name.startswith("_")
    ]
    print(f"  Columns    : {len(data_columns)}")

    # ── 5c: Per-column analysis ─────────────────────────────────────────────
    csv_rows = []      # rows for the per-schema CSV output

    for col_name, col_type in data_columns:
        print(f"    Analysing: {col_name:<40} [{col_type}]")

        # ── Null count ───────────────────────────────────────────────────────
        null_count = df.filter(F.col(col_name).isNull()).count()

        # ── Distinct value count ─────────────────────────────────────────────
        distinct_count = df.select(col_name).dropna().distinct().count()

        # ── Min / Max (cast everything to string for uniformity) ─────────────
        stats = df.select(
            F.min(F.col(col_name).cast("string")).alias("min_val"),
            F.max(F.col(col_name).cast("string")).alias("max_val"),
        ).collect()[0]
        min_val = str(stats["min_val"]) if stats["min_val"] is not None else ""
        max_val = str(stats["max_val"]) if stats["max_val"] is not None else ""

        # ── Top N value frequency ────────────────────────────────────────────
        top_values_df = (
            df.select(F.col(col_name).cast("string").alias("value"))
              .dropna()
              .groupBy("value")
              .agg(F.count("*").alias("value_count"))
              .orderBy(F.col("value_count").desc())
              .limit(MAX_VAL)
        )
        top_values = top_values_df.collect()

        # Pick the top value label for profile table
        top_value = top_values[0]["value"] if top_values else ""

        # ── Build CSV value-mapping rows ─────────────────────────────────────
        for row in top_values:
            val = row["value"]
            cnt = row["value_count"]
            pct = round((cnt / total_rows) * 100, 2) if total_rows > 0 else 0.0
            csv_rows.append({
                "schema_type"   : st,
                "column_name"   : col_name,
                "data_type"     : col_type,
                "value"         : val,
                "value_count"   : cnt,
                "value_pct"     : pct,
                "total_rows"    : total_rows,
                "null_count"    : null_count,
                "distinct_count": distinct_count,
                "min_value"     : min_val,
                "max_value"     : max_val,
            })

        # ── Accumulate profile row ───────────────────────────────────────────
        all_profile_rows.append({
            "schema_type"   : st,
            "column_name"   : col_name,
            "data_type"     : col_type,
            "total_rows"    : total_rows,
            "null_count"    : null_count,
            "null_pct"      : round((null_count / total_rows) * 100, 2) if total_rows else 0.0,
            "distinct_count": distinct_count,
            "min_value"     : min_val,
            "max_value"     : max_val,
            "top_value"     : top_value,
        })

        # ── Accumulate QuickSight value rows (top N only) ────────────────────
        for rank, row in enumerate(top_values[:TOP_N], start=1):
            val = row["value"]
            cnt = row["value_count"]
            pct = round((cnt / total_rows) * 100, 2) if total_rows else 0.0
            all_values_rows.append({
                "schema_type"  : st,
                "column_name"  : col_name,
                "data_type"    : col_type,
                "value"        : val,
                "value_count"  : cnt,
                "value_pct"    : pct,
                "value_rank"   : rank,
                "total_rows"   : total_rows,
            })

    # ── 5d: Write per-schema CSV value-mapping report ───────────────────────
    if csv_rows:
        import pandas as pd
        csv_pdf    = pd.DataFrame(csv_rows)
        # Sort: schema_type → column_name → value_count desc
        csv_pdf    = csv_pdf.sort_values(
            ["schema_type", "column_name", "value_count"],
            ascending=[True, True, False]
        )
        csv_bytes  = csv_pdf.to_csv(index=False).encode("utf-8")
        csv_key    = (
            f"{CONFIG['output_prefix']}csv_analysis/"
            f"{st}_column_value_mapping.csv"
        )
        s3c.put_object(
            Bucket      = CONFIG["output_bucket"],
            Key         = csv_key,
            Body        = csv_bytes,
            ContentType = "text/csv",
        )
        print(f"\n  ✅ CSV report → s3://{CONFIG['output_bucket']}/{csv_key}")
        print(f"     Rows in CSV : {len(csv_pdf):,}")
        print(f"\n  Preview (first 10 rows):")
        print(csv_pdf.head(10).to_string(index=False))

    # ── 5e: Accumulate summary row ───────────────────────────────────────────
    dates_for_st = sorted(set(f["date_folder"] for f in entries))
    all_summary_rows.append({
        "schema_type"   : st,
        "total_columns" : len(data_columns),
        "total_rows"    : total_rows,
        "file_count"    : len(entries),
        "date_count"    : len(dates_for_st),
        "date_min"      : dates_for_st[0]  if dates_for_st else "",
        "date_max"      : dates_for_st[-1] if dates_for_st else "",
        "date_list"     : ",".join(dates_for_st),
        "analysed_at"   : datetime.utcnow().isoformat() + "Z",
    })

