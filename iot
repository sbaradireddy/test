# ── Helper: register / update a Glue table ──────────────────────────────────
def register_glue_table(table_name: str, s3_location: str, spark_df):
    """
    Register a Parquet-backed Spark DataFrame as a Glue Catalog table
    so it is queryable via Athena and visible to QuickSight.
    """
    cols = []
    for field in spark_df.schema.fields:
        if field.name == "schema_type":
            continue   # partition key — added separately
        glue_type = {
            "StringType()"   : "string",
            "LongType()"     : "bigint",
            "IntegerType()"  : "int",
            "DoubleType()"   : "double",
            "FloatType()"    : "float",
            "BooleanType()"  : "boolean",
            "TimestampType()": "timestamp",
            "DateType()"     : "date",
        }.get(str(field.dataType), "string")
        cols.append({"Name": field.name, "Type": glue_type})

    table_input = {
        "Name"       : table_name,
        "Description": f"Penske IoT analysis — {table_name}",
        "StorageDescriptor": {
            "Columns"           : cols,
            "Location"          : s3_location,
            "InputFormat"       : "org.apache.hadoop.hive.ql.io.parquet.MapredParquetInputFormat",
            "OutputFormat"      : "org.apache.hadoop.hive.ql.io.parquet.MapredParquetOutputFormat",
            "SerdeInfo"         : {
                "SerializationLibrary": "org.apache.hadoop.hive.ql.io.parquet.serde.ParquetHiveSerDe",
                "Parameters"         : {"serialization.format": "1"},
            },
            "Compressed"        : False,
            "StoredAsSubDirectories": True,
        },
        "PartitionKeys": [{"Name": "schema_type", "Type": "string"}]
            if table_name != "schema_summary" else [],
        "TableType"  : "EXTERNAL_TABLE",
        "Parameters" : {
            "classification"          : "parquet",
            "EXTERNAL"                : "TRUE",
            "parquet.compression"     : "SNAPPY",
            "projection.enabled"      : "false",
        },
    }

    try:
        glue_client.create_table(DatabaseName=glue_db, TableInput=table_input)
        print(f"  ✅ Created  : {glue_db}.{table_name}")
    except glue_client.exceptions.AlreadyExistsException:
        glue_client.update_table(DatabaseName=glue_db, TableInput=table_input)
        print(f"  ✅ Updated  : {glue_db}.{table_name}")

    # Repair partitions after write
    try:
        athena = boto3.client("athena")
        athena.start_query_execution(
            QueryString             = f"MSCK REPAIR TABLE {glue_db}.{table_name}",
            ResultConfiguration     = {
                "OutputLocation": f"s3://{CONFIG['output_bucket']}/athena-query-results/"
            },
        )
        print(f"  ✅ Athena partition repair triggered for {table_name}")
    except Exception as e:
        print(f"  ℹ️  Partition repair skipped ({e})")


