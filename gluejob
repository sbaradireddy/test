from awsglue.context import GlueContext
from pyspark.context import SparkContext

sc = SparkContext.getOrCreate()
glueContext = GlueContext(sc)
spark = glueContext.spark_session

SRC = "s3://pske-stg-maintenance/projects/ard-iot-data/ps.NA_PENSKE_TRIAL.measurements.results/"
DST = "s3://pske-stg-maintenance/projects/ard-iot-data-compacted/"
TARGET_MB = 256

# No mergeSchema -> reads schema from one file, avoids the 885-task merge
df = (spark.read
      .option("recursiveFileLookup", "true")
      .parquet(SRC))

# Cheap row count (distributed, no driver pull)
total = df.count()
print(f"Total rows: {total:,}")

# Estimate output file count from a small sampled write size instead of toPandas.
# Safer: just base it on row count; tune divisor to your row width.
n_files = max(1, total // 2_000_000)   # ~2M wide rows per 256MB file (rough)
print(f"Output files: {n_files}")

(df.repartition(n_files)
   .write
   .mode("overwrite")
   .option("compression", "snappy")
   .parquet(DST))

print(f"Done -> {DST}")
