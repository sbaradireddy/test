def register_glue_table(table_name, s3_location, schema, partition_key=None):
    GLUE_TYPE = {
        "StringType()" : "string", "LongType()"   : "bigint",
        "IntegerType()": "int",    "DoubleType()"  : "double",
        "FloatType()"  : "float",  "BooleanType()" : "boolean",
    }
    cols = [
        {"Name": f.name, "Type": GLUE_TYPE.get(str(f.dataType), "string")}
        for f in schema.fields if f.name != partition_key
    ]
    part_keys = [{"Name": partition_key, "Type": "string"}] if partition_key else []
    tbl = {
        "Name": table_name,
        "StorageDescriptor": {
            "Columns": cols, "Location": s3_location,
            "InputFormat" : "org.apache.hadoop.hive.ql.io.parquet.MapredParquetInputFormat",
            "OutputFormat": "org.apache.hadoop.hive.ql.io.parquet.MapredParquetOutputFormat",
            "SerdeInfo": {
                "SerializationLibrary":
                    "org.apache.hadoop.hive.ql.io.parquet.serde.ParquetHiveSerDe",
                "Parameters": {"serialization.format": "1"},
            },
            "Compressed": False, "StoredAsSubDirectories": True,
        },
        "PartitionKeys": part_keys,
        "TableType"    : "EXTERNAL_TABLE",
        "Parameters"   : {"classification": "parquet", "EXTERNAL": "TRUE"},
    }
    try:
        glue_client.create_table(DatabaseName=glue_db, TableInput=tbl)
        print(f"  ✅ Created  {glue_db}.{table_name}")
    except glue_client.exceptions.AlreadyExistsException:
        glue_client.update_table(DatabaseName=glue_db, TableInput=tbl)
        print(f"  ✅ Updated  {glue_db}.{table_name}")
    try:
        boto3.client("athena").start_query_execution(
            QueryString         = f"MSCK REPAIR TABLE {glue_db}.{table_name}",
            ResultConfiguration = {"OutputLocation":
                f"s3://{CONFIG['output_bucket']}/athena-query-results/"},
        )
        print(f"     Partition repair triggered")
    except Exception as e:
        print(f"     Partition repair skipped: {e}")


