# CELL 4 ── Helper: detect array-indexed column pattern
#            campaignTargets_0_matchState → logical name = "campaignTargets_matchState"
#            campaign_name               → logical name = "campaign_name"  (unchanged)
# ─────────────────────────────────────────────────────────────────────────────

ARRAY_IDX_RE = re.compile(r"^(.+?)_\d+_(.+)$")

def logical_name(col_name: str) -> str:
    """
    Strip array index from flattened array column names.
    campaignTargets_0_matchState  → campaignTargets_matchState
    campaignTargets_42_target_id  → campaignTargets_target_id
    campaign_name                 → campaign_name
    """
    m = ARRAY_IDX_RE.match(col_name)
    if m:
        return f"{m.group(1)}_{m.group(2)}"
    return col_name


def canonical_type(spark_field_type) -> str:
    t = str(spark_field_type).lower()
    t = re.sub(r"type\b", "", t).strip()
    t = re.sub(r"\(.*?\)", "", t).strip()
    return t


