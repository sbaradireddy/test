def list_parquet_files(bucket, prefix, date_from, date_to, schema_regex):
    s3 = boto3.client("s3")
    paginator = s3.get_paginator("list_objects_v2")
    files = []
    for page in paginator.paginate(Bucket=bucket, Prefix=prefix):
        for obj in page.get("Contents", []):
            key = obj["Key"]
            if not key.lower().endswith(".parquet"):
                continue
            relative = key[len(prefix):].strip("/")
            parts    = relative.split("/")
            if len(parts) < 3:
                continue
            date_folder = parts[0]
            time_folder = parts[1]
            filename    = parts[-1]
            if date_from and date_folder < date_from:
                continue
            if date_to   and date_folder > date_to:
                continue
            stem  = filename.rsplit(".parquet", 1)[0]
            match = re.match(schema_regex, stem, re.IGNORECASE)
            schema_type = match.group(1) if match else stem
            files.append({
                "s3_uri"      : f"s3://{bucket}/{key}",
                "date_folder" : date_folder,
                "time_folder" : time_folder,
                "filename"    : filename,
                "schema_type" : schema_type,
            })
    return files


