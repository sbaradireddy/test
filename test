# CELL 6 ── Narrow schema analyser (per-column, for schemas ≤ threshold)
# ─────────────────────────────────────────────────────────────────────────────

def analyse_narrow_schema(df, schema_type, total_rows, max_val, top_n):
    """Per-column analysis for schemas with few columns."""
    data_fields = [
        (f.name, f.dataType)
        for f in df.schema.fields
        if not f.name.startswith("_")
    ]

    profile_rows = []
    values_rows  = []
    csv_rows     = []

    for col_name, col_dtype in data_fields:
        col_type_str = canonical_type(col_dtype)

        try:
            col_df = df.select(
                F.col(f"`{col_name}`").cast("string").alias("value")
            ).toDF("value")
        except Exception as e:
            print(f"    ⚠️  select failed [{col_name}]: {e}")
            continue

        try:
            null_count = col_df.filter(F.col("value").isNull()).count()
        except Exception:
            null_count = 0

        try:
            distinct_count = col_df.dropna().distinct().count()
        except Exception:
            distinct_count = 0

        min_val, max_val_s = "", ""
        try:
            stats = col_df.dropna().agg(
                F.min("value").alias("mn"),
                F.max("value").alias("mx"),
            ).collect()[0]
            min_val   = str(stats["mn"]) if stats["mn"] else ""
            max_val_s = str(stats["mx"]) if stats["mx"] else ""
        except Exception:
            pass

        top_values = []
        try:
            top_values = (
                col_df.dropna()
                .groupBy("value")
                .agg(F.count("*").alias("cnt"))
                .orderBy(F.col("cnt").desc())
                .limit(max_val)
                .collect()
            )
        except Exception as e:
            print(f"    ⚠️  value freq failed [{col_name}]: {e}")

        top_value  = str(top_values[0]["value"]) if top_values else ""
        null_pct   = round((null_count / total_rows) * 100, 2) if total_rows else 0.0

        print(f"    ✓ {col_name:<55} null={null_count}  dist={distinct_count}  top='{top_value[:25]}'")

        profile_rows.append({
            "schema_type"   : str(schema_type),
            "column_name"   : str(col_name),
            "original_name" : str(col_name),
            "data_type"     : str(col_type_str),
            "total_rows"    : int(total_rows),
            "null_count"    : int(null_count),
            "null_pct"      : null_pct,
            "distinct_count": int(distinct_count),
            "min_value"     : str(min_val),
            "max_value"     : str(max_val_s),
            "top_value"     : str(top_value),
        })

        for rank, row in enumerate(top_values[:top_n], start=1):
            val_str = str(row["value"]) if row["value"] else ""
            val_cnt = int(row["cnt"])
            val_pct = round((val_cnt / total_rows) * 100, 2) if total_rows else 0.0
            values_rows.append({
                "schema_type"  : str(schema_type),
                "column_name"  : str(col_name),
                "original_name": str(col_name),
                "data_type"    : str(col_type_str),
                "value"        : val_str,
                "value_count"  : val_cnt,
                "value_pct"    : val_pct,
                "value_rank"   : int(rank),
                "total_rows"   : int(total_rows),
            })

        for row in top_values:
            val_str = str(row["value"]) if row["value"] else ""
            val_cnt = int(row["cnt"])
            val_pct = round((val_cnt / total_rows) * 100, 2) if total_rows else 0.0
            csv_rows.append({
                "schema_type"   : str(schema_type),
                "column_name"   : str(col_name),
                "original_name" : str(col_name),
                "data_type"     : str(col_type_str),
                "value"         : val_str,
                "value_count"   : val_cnt,
                "value_pct"     : val_pct,
                "total_rows"    : int(total_rows),
                "null_count"    : int(null_count),
                "distinct_count": int(distinct_count),
                "min_value"     : str(min_val),
                "max_value"     : str(max_val_s),
            })

    return profile_rows, values_rows, csv_rows


