# ─────────────────────────────────────────────────────────────────────────────
# CELL 5 ── Bulk unpivot analyser (for wide schemas)
#
#  Instead of 700 separate Spark jobs (one per column), this function:
#    1. Casts ALL columns to string in one select
#    2. Uses stack() to unpivot: (col_name, value) — ONE Spark job
#    3. Maps physical col_name → logical_name (strips array index)
#    4. Groups by logical_name and value → counts
#    Returns a list of profile rows and value rows ready for accumulation.
# ─────────────────────────────────────────────────────────────────────────────

def analyse_wide_schema(df, schema_type, total_rows, max_val, top_n):
    """
    Bulk unpivot analysis for schemas with many columns.
    Returns (profile_rows, values_rows, csv_rows).
    """
    # Step 1: cast all non-internal columns to string, collect names
    data_cols = [f.name for f in df.schema.fields if not f.name.startswith("_")]
    n = len(data_cols)
    print(f"    Wide schema: {n} columns → bulk unpivot")

    # Step 2: build stack() expression
    # stack(N, 'col1', col1, 'col2', col2, ...) AS (col_name, value)
    # Split into batches of 200 to avoid query plan explosion
    BATCH = 200
    long_dfs = []

    for batch_start in range(0, n, BATCH):
        batch_cols = data_cols[batch_start : batch_start + BATCH]
        stack_args = ", ".join(
            f"'{c}', CAST(`{c}` AS STRING)"
            for c in batch_cols
        )
        stack_expr = f"stack({len(batch_cols)}, {stack_args}) AS (col_name, value)"
        try:
            batch_df = df.select(F.expr(stack_expr))
            long_dfs.append(batch_df)
        except Exception as e:
            print(f"    ⚠️  Batch {batch_start}-{batch_start+BATCH} failed: {e}")

    if not long_dfs:
        print(f"    ⚠️  All batches failed for {schema_type}")
        return [], [], []

    # Union all batches into one long DF
    long_df = long_dfs[0]
    for ldf in long_dfs[1:]:
        long_df = long_df.union(ldf)

    # Step 3: add logical name column (strips array index)
    logical_name_udf = F.udf(logical_name, StringType())
    long_df = long_df.withColumn("logical_col", logical_name_udf(F.col("col_name")))

    # Step 4: group by (logical_col, value) → count
    # This is ONE Spark job covering all columns
    freq_df = (
        long_df
        .filter(F.col("value").isNotNull() & (F.col("value") != ""))
        .groupBy("logical_col", "value")
        .agg(F.count("*").alias("cnt"))
        .cache()
    )

    # Step 5: null counts per logical column
    null_df = (
        long_df
        .filter(F.col("value").isNull() | (F.col("value") == ""))
        .groupBy("logical_col")
        .agg(F.count("*").alias("null_cnt"))
    )

    # Step 6: distinct count per logical column
    distinct_df = (
        freq_df
        .groupBy("logical_col")
        .agg(F.countDistinct("value").alias("distinct_cnt"))
    )

    # Collect frequency (top N per logical col)
    # Use window function to rank
    from pyspark.sql.window import Window
    w = Window.partitionBy("logical_col").orderBy(F.col("cnt").desc())
    top_df = (
        freq_df
        .withColumn("rank", F.row_number().over(w))
        .filter(F.col("rank") <= max_val)
    )

    # Min/Max per logical col (from string sort)
    minmax_df = (
        freq_df
        .groupBy("logical_col")
        .agg(
            F.min("value").alias("min_val"),
            F.max("value").alias("max_val"),
            F.sum("cnt").alias("total_non_null"),
        )
    )

    # Collect all to driver
    top_rows     = top_df.collect()
    null_rows    = {r["logical_col"]: int(r["null_cnt"])    for r in null_df.collect()}
    distinct_rows= {r["logical_col"]: int(r["distinct_cnt"])for r in distinct_df.collect()}
    minmax_rows  = {r["logical_col"]: r                     for r in minmax_df.collect()}

    freq_df.unpersist()

    # Group top_rows by logical_col
    by_col = defaultdict(list)
    for r in top_rows:
        by_col[r["logical_col"]].append(r)

    profile_rows = []
    values_rows  = []
    csv_rows     = []

    for lc in sorted(by_col.keys()):
        rows       = by_col[lc]
        null_count = null_rows.get(lc, 0)
        dist_count = distinct_rows.get(lc, 0)
        mm         = minmax_rows.get(lc)
        min_val    = str(mm["min_val"]) if mm and mm["min_val"] else ""
        max_val    = str(mm["max_val"]) if mm and mm["max_val"] else ""
        top_value  = str(rows[0]["value"]) if rows else ""
        null_pct   = round((null_count / total_rows) * 100, 2) if total_rows else 0.0

        profile_rows.append({
            "schema_type"   : str(schema_type),
            "column_name"   : str(lc),
            "original_name" : str(lc),
            "data_type"     : "string",
            "total_rows"    : int(total_rows),
            "null_count"    : int(null_count),
            "null_pct"      : null_pct,
            "distinct_count": int(dist_count),
            "min_value"     : min_val,
            "max_value"     : max_val,
            "top_value"     : top_value,
        })

        for rank, row in enumerate(rows[:top_n], start=1):
            val_str = str(row["value"]) if row["value"] else ""
            val_cnt = int(row["cnt"])
            val_pct = round((val_cnt / total_rows) * 100, 2) if total_rows else 0.0

            values_rows.append({
                "schema_type"  : str(schema_type),
                "column_name"  : str(lc),
                "original_name": str(lc),
                "data_type"    : "string",
                "value"        : val_str,
                "value_count"  : val_cnt,
                "value_pct"    : val_pct,
                "value_rank"   : int(rank),
                "total_rows"   : int(total_rows),
            })

            if rank <= max_val:
                csv_rows.append({
                    "schema_type"   : str(schema_type),
                    "column_name"   : str(lc),
                    "original_name" : str(lc),
                    "data_type"     : "string",
                    "value"         : val_str,
                    "value_count"   : val_cnt,
                    "value_pct"     : val_pct,
                    "total_rows"    : int(total_rows),
                    "null_count"    : int(null_count),
                    "distinct_count": int(dist_count),
                    "min_value"     : min_val,
                    "max_value"     : max_val,
                })

    print(f"    ✅ Wide analysis done: {len(profile_rows)} logical columns")
    return profile_rows, values_rows, csv_rows


